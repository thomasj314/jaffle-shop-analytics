[Unit]
Description=dbt Docs Server
After=network.target

[Service]
User=ubuntu
WorkingDirectory=/home/ubuntu/jaffle-shop-analytics
Environment="PATH=/home/ubuntu/.local/bin:/usr/local/bin:/usr/bin:/bin"
ExecStart=/home/ubuntu/.local/bin/dbt docs serve --host 0.0.0.0 --port 8080 --no-browser
Restart=always

[Install]
WantedBy=multi-user.target
